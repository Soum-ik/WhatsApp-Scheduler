{
  "name": "whatsapp-sch",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --hot run index.ts",
    "test": "bun test",
    "db:new": "bun run scripts/new-migration.ts",
    "db:migrate": "bun run src/infra/db/migrator.ts",
    "db:dump": "mkdir -p schema && cat migrations/*.sql > schema/schema.sql",
    "db:dump:dc": "bun run scripts/dump-schema.ts" 

  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "bullmq": "^5.74.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  }
}
